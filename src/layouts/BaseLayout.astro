---
import { ClientRouter, fade } from 'astro:transitions';
import '../styles/global.css';
import CRTOverlay from '../components/CRTOverlay';
import AmbientGlow from '../components/AmbientGlow';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}


const {
  title = 'Dashboard Portfolio',
  description = 'ダッシュボード型ポートフォリオサイト',
} = Astro.props;

// Google Analytics 4 Measurement ID
const GA_MEASUREMENT_ID = 'G-3XG4W5WQD1';

const currentPath = Astro.url.pathname;
const isActive = (path: string) => {
  if (path === '/' && currentPath === '/') return true;
  if (path !== '/' && currentPath.startsWith(path)) return true;
  return false;
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100;300;400;600;700;900&family=Noto+Sans+JP:wght@300;400;700&display=swap" rel="stylesheet" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="RK / Portfolio" href="/rss.xml" />
    
    <!-- OGP Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    {Astro.props.ogImage && <meta property="og:image" content={new URL(Astro.props.ogImage, Astro.site)} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {Astro.props.ogImage && <meta name="twitter:image" content={new URL(Astro.props.ogImage, Astro.site)} />}

    <ClientRouter />

    <!-- Dark mode script (run before render to prevent flash) -->
    <script is:inline>
      (function() {
        // Default to dark — light is the opt-in
        const stored = localStorage.getItem('theme');
        const theme = stored || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>

    <!-- Google Analytics 4 -->
    <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', GA_MEASUREMENT_ID);
    </script>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}></script>

  </head>
  <body>
    <!-- Deep background glow -->
    <div transition:persist="ambient-glow">
      <AmbientGlow client:only="react" />
    </div>

    <div transition:persist="crt-overlay">
      <CRTOverlay client:only="react" />
    </div>



    <header class="header">
      <div class="container header-content">
        <a href="/" class="logo" transition:name="site-logo">RK / PORTFOLIO</a>
        <nav class="nav-links">
          <a href="/posts" class={`nav-link ${isActive('/posts') ? 'nav-link--accent' : ''}`}>Posts</a>
          <a href="/about" class={`nav-link ${isActive('/about') ? 'nav-link--accent' : ''}`}>About</a>
          <a href="/colophon" class={`nav-link ${isActive('/colophon') ? 'nav-link--accent' : ''}`}>Colophon</a>
          <a href="/talks" class={`nav-link ${isActive('/talks') ? 'nav-link--accent' : ''}`}>Talks</a>
        </nav>
        <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
          <span class="sun-icon">LIGHT</span>
          <span class="moon-icon">DARK</span>
        </button>
      </div>
    </header>

    <main class="main" transition:animate={fade({ duration: '0.15s' })}>
      <div class="container">
        <slot />
      </div>
    </main>

    <script>
      function initTheme() {
        const stored = localStorage.getItem('theme');
        const theme = stored || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      }

      function setupThemeToggle() {
        const toggle = document.getElementById('theme-toggle');
        toggle?.addEventListener('click', (e) => {
          const current = document.documentElement.getAttribute('data-theme');
          const next = current === 'dark' ? 'light' : 'dark';

          // View Transition API 非対応ブラウザではフォールバック
          // @ts-ignore
          if (!document.startViewTransition) {
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
            return;
          }

          // @ts-ignore
          document.documentElement.setAttribute('data-theme-transition', 'true');

          // @ts-ignore
          const transition = document.startViewTransition(() => {
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
          });

          // クリック位置を起点に円形展開アニメーション
          const x = (e as MouseEvent).clientX;
          const y = (e as MouseEvent).clientY;
          const endRadius = Math.hypot(
            Math.max(x, window.innerWidth - x),
            Math.max(y, window.innerHeight - y)
          );

          transition.ready.then(() => {
            document.documentElement.animate(
              {
                clipPath: [
                  `circle(0px at ${x}px ${y}px)`,
                  `circle(${endRadius}px at ${x}px ${y}px)`,
                ],
              },
              {
                duration: 500,
                easing: 'ease-in-out',
                pseudoElement: '::view-transition-new(root)',
              }
            );
          });

          transition.finished.finally(() => {
            document.documentElement.removeAttribute('data-theme-transition');
          });
        });
      }

      // 初期化とイベントリスナー設定
      // astro:page-load は初回ロード時とページ遷移後に発火する
      document.addEventListener('astro:page-load', () => {
        setupThemeToggle();
      });

      // astro:after-swap は新しいHTMLに入れ替わった直後（表示前）に発火
      // ここでテーマを再適用しないと、一瞬デフォルトテーマに戻るチラつきや、属性消失によるアイコン重複が起きる
      document.addEventListener('astro:after-swap', () => {
        initTheme();
      });
    </script>

    <!-- Vercel Speed Insights -->
    <script is:inline>
      window.si = window.si || function () { (window.siq = window.siq || []).push(arguments); };
    </script>
    <script async defer src="/_vercel/speed-insights/script.js"></script>

    <!-- Vercel Analytics -->
    <script is:inline>
      window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
    </script>
    <script async defer src="/_vercel/insights/script.js"></script>
  </body>
</html>
