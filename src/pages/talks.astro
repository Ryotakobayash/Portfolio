---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import talksData from '../data/talks.json';

const upcomingTalks = talksData.upcoming || [];
const pastTalks = talksData.past || [];
---

<BaseLayout title="Talks | RK / Portfolio" description="Upcoming and past talks, presentations, and slides">
  <div class="talks-page">
    <header class="talks-header">
      <h1 class="page-title">Talks</h1>
      <p class="page-description">
        登壇予定および過去の登壇資料（Speaker Deck / Marp）をまとめています。
      </p>
    </header>

    <!-- Upcoming Talks Timeline -->
    <div class="section-divider"><span class="section-divider__label">01 · Upcoming</span></div>
    <section class="bento-card">
      {upcomingTalks.length > 0 ? (
        <ul class="timeline">
          {upcomingTalks.map((talk) => (
            <li class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <span class="talk-date">{talk.date}</span>
                <span class="talk-event">{talk.event}</span>
                <h3 class="talk-title">{talk.title}</h3>
                <span class="talk-status">{talk.status}</span>
              </div>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-muted">Currently, there are no upcoming talks scheduled.</p>
      )}
    </section>

    <!-- Past Talks / Slides -->
    <div class="section-divider"><span class="section-divider__label">02 · Archives & Slides</span></div>
    <div class="talks-grid">
      {pastTalks.map((talk) => (
        <section class="bento-card talk-card">
          <div class="talk-info">
            <span class="talk-date">{talk.date}</span>
            <span class="talk-event">{talk.event}</span>
            <h3 class="talk-title">{talk.title}</h3>
            {talk.link && (
              <a href={talk.link} target="_blank" rel="noopener noreferrer" class="talk-link link-arrow">
                View on {talk.type} →
              </a>
            )}
          </div>
          
          {talk.embedUrl ? (
            <div class="slide-embed-container">
              <iframe
                class="speakerdeck-iframe"
                src={talk.embedUrl}
                title={talk.title}
                allowfullscreen="true"
                mozallowfullscreen="true"
                webkitallowfullscreen="true"
                data-ratio="1.7777777777777777"
              ></iframe>
            </div>
          ) : (
            <div class="slide-placeholder">
              <span class="text-muted text-sm">No slide embed available.</span>
            </div>
          )}
        </section>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .talks-page {
    max-width: 800px;
    margin: 0 auto;
    padding-bottom: var(--spacing-2xl);
  }

  .talks-header {
    margin-bottom: var(--spacing-xl);
  }

  .page-title {
    font-size: 3rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    margin-bottom: var(--spacing-md);
    color: var(--color-primary);
  }

  .page-description {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 600px;
  }

  /* Section Divider */
  .section-divider {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: var(--spacing-2xl) 0 var(--spacing-lg);
  }

  .section-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  /* Timeline */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .timeline-item {
    display: flex;
    gap: var(--spacing-md);
    position: relative;
  }

  .timeline-marker {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: var(--color-primary);
    border: 2px solid var(--color-bg-card);
    position: relative;
    z-index: 2;
    margin-top: 4px;
    flex-shrink: 0;
  }

  .timeline-item:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 16px;
    bottom: calc(var(--spacing-lg) * -1);
    left: 5px;
    width: 2px;
    background-color: var(--color-border);
    z-index: 1;
  }

  .timeline-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  /* Talk Info Items */
  .talk-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .talk-event {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-accent-2);
    letter-spacing: 0.1em;
  }

  .talk-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 4px 0;
  }

  .talk-status {
    display: inline-block;
    padding: 2px 8px;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    background-color: var(--color-bg-secondary);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    align-self: flex-start;
    margin-top: 4px;
  }

  /* Past Talks */
  .talks-grid {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xl);
  }

  .talk-card {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .talk-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .talk-link {
    font-size: 0.8rem;
    align-self: flex-start;
    margin-top: var(--spacing-sm);
  }

  /* Responsive iframe container for 16:9 slides */
  .slide-embed-container {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    height: 0;
    overflow: hidden;
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
  }

  .speakerdeck-iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .slide-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 200px;
    background-color: var(--color-bg-secondary);
    border: 1px dashed var(--color-border);
  }
</style>
