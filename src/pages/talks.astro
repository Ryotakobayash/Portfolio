---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_NAME } from '../consts';
import TalkSearch, { type TalkMeta } from '../components/TalkSearch';
import { getAllTalks, talkSlug, hasSlideBody } from '../utils/talks';

const allEntries = await getAllTalks();

interface UpcomingTalk {
  id: string;
  date: string;
  event: string;
  title: string;
  url?: string;
  isExternal: boolean;
  isPublished: boolean;
}

const today = new Date().toISOString().slice(0, 10);
const isProd = import.meta.env.PROD;

const upcomingTalks: UpcomingTalk[] = allEntries
  .filter((entry) => entry.data.date >= today)
  .sort((a, b) => (a.data.date < b.data.date ? -1 : 1))
  .map((entry) => {
    const slug = talkSlug(entry);
    const hasBody = hasSlideBody(entry);
    const isPublished = entry.data.published === true;
    const slidesAccessible = hasBody && (isPublished || !isProd);

    const url = slidesAccessible
      ? `/slides/${slug}`
      : entry.data.externalUrl;

    return {
      id: entry.id,
      date: entry.data.date,
      event: entry.data.event,
      title: entry.data.title,
      url,
      isExternal: !!url && !slidesAccessible,
      isPublished,
    };
  });

const archive: TalkMeta[] = allEntries
  .filter((entry) => entry.data.date < today)
  .map((entry) => {
    const slug = talkSlug(entry);
    const hasBody = hasSlideBody(entry);
    const isPublished = entry.data.published === true;
    const slidesAccessible = hasBody && (isPublished || !isProd);

    let href: string;
    let type: TalkMeta['type'];
    let status: TalkMeta['status'];

    if (slidesAccessible) {
      href = `/slides/${slug}`;
      type = 'Slides';
      status = isPublished ? 'published' : 'draft-slides';
    } else if (entry.data.externalUrl) {
      href = entry.data.externalUrl;
      type = 'Speaker Deck';
      status = isPublished ? 'published' : 'draft-slides';
    } else if (entry.data.embedUrl) {
      href = entry.data.embedUrl;
      type = 'Speaker Deck';
      status = isPublished ? 'published' : 'draft-slides';
    } else {
      href = '#';
      type = 'Speaker Deck';
      status = isPublished ? 'no-slides' : 'draft-slides';
    }

    const isExternal = href !== '#' && !href.startsWith('/');

    return {
      id: entry.id,
      title: entry.data.title,
      date: entry.data.date,
      event: entry.data.event,
      description: entry.data.description,
      tags: entry.data.tags,
      href,
      isExternal,
      type,
      status,
    };
  })
  .sort((a, b) => (a.date < b.date ? 1 : -1));

const tagCount = new Map<string, number>();
archive.forEach((t) => t.tags.forEach((tag) => tagCount.set(tag, (tagCount.get(tag) || 0) + 1)));
const allTags = Array.from(tagCount.entries())
  .sort((a, b) => b[1] - a[1])
  .map(([tag]) => tag);
---

<BaseLayout title={`Talks | ${SITE_NAME}`} description="Upcoming and past talks, presentations, and slides">
  <div class="talks-page">
    <header class="talks-header">
      <h1 class="page-title">Talks</h1>
      <div class="stats-row">
        <span class="stat-item">{archive.length} Talks</span>
        <span class="stat-separator">/</span>
        <span class="stat-item">{allTags.length} Tags</span>
        {archive[0] && (
          <>
            <span class="stat-separator">/</span>
            <span class="stat-item">Latest: {archive[0].date}</span>
          </>
        )}
      </div>
    </header>

    {upcomingTalks.length > 0 && (
      <>
        <div class="section-divider"><span class="section-divider__label">Upcoming</span></div>
        <section class="bento-card">
          <ul class="timeline">
            {upcomingTalks.map((talk) => {
              const hasUrl = !!talk.url;
              const Inner = (
                <>
                  <span class="talk-date">{talk.date}</span>
                  <span class="talk-event">
                    {talk.event}
                    {hasUrl && talk.isExternal && <span class="talk-event-icon" aria-hidden="true"> ↗</span>}
                  </span>
                  <h3 class="talk-title">{talk.title}</h3>
                  {!talk.isPublished && <span class="talk-status">準備中</span>}
                </>
              );
              return (
                <li class="timeline-item">
                  <div class="timeline-marker"></div>
                  {hasUrl ? (
                    <a
                      class="timeline-content timeline-content--link"
                      href={talk.url}
                      target={talk.isExternal ? '_blank' : undefined}
                      rel={talk.isExternal ? 'noopener noreferrer' : undefined}
                    >
                      {Inner}
                    </a>
                  ) : (
                    <div class="timeline-content">{Inner}</div>
                  )}
                </li>
              );
            })}
          </ul>
        </section>
      </>
    )}

    <div class="section-divider"><span class="section-divider__label">Archive</span></div>
    <TalkSearch client:idle talks={archive} allTags={allTags} />
  </div>
</BaseLayout>

<style>
  .talks-page {
    max-width: 800px;
    margin: 0 auto;
    padding-bottom: var(--spacing-2xl);
  }

  .talks-header {
    margin-bottom: var(--spacing-xl);
  }

  .page-title {
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    margin-bottom: var(--spacing-sm);
    color: var(--color-primary);
  }

  .stats-row {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .stat-item {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .stat-separator {
    color: var(--color-border);
  }

  .section-divider {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: var(--spacing-2xl) 0 var(--spacing-lg);
  }

  .section-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .timeline-item {
    display: flex;
    gap: var(--spacing-md);
    position: relative;
  }

  .timeline-marker {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: var(--color-primary);
    border: 2px solid var(--color-bg-card);
    position: relative;
    z-index: 2;
    margin-top: 4px;
    flex-shrink: 0;
  }

  .timeline-item:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 16px;
    bottom: calc(var(--spacing-lg) * -1);
    left: 5px;
    width: 2px;
    background-color: var(--color-border);
    z-index: 1;
  }

  .timeline-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .timeline-content--link {
    color: inherit;
    text-decoration: none;
    padding: var(--spacing-sm);
    margin: calc(var(--spacing-sm) * -1);
    border: 1px solid transparent;
    transition:
      border-color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .timeline-content--link:hover {
    border-color: var(--color-primary);
    background-color: var(--color-bg-card);
  }

  .timeline-content--link:hover .talk-title {
    color: var(--color-primary);
  }

  .talk-event-icon {
    color: var(--color-text-muted);
    font-weight: 400;
    margin-left: 4px;
  }

  .talk-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .talk-event {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-accent-2);
    letter-spacing: 0.1em;
  }

  .talk-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 4px 0;
    transition: color var(--transition-fast);
  }

  .talk-status {
    display: inline-block;
    padding: 2px 8px;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    background-color: var(--color-bg-secondary);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    align-self: flex-start;
    margin-top: 4px;
  }
</style>
