---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { getPublishedPosts } from '../../utils/posts';
import StickyToc from '../../components/StickyToc';
import ImageZoom from '../../components/ImageZoom';
import ArticlePerformance from '../../components/ArticlePerformance';
import ShareButtons from '../../components/ShareButtons';
import RelatedPosts from '../../components/RelatedPosts';
import CustomImage from '../../components/CustomImage.astro';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: (post.data.slug || post.id) },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const slug = (post.data.slug || post.id);
const { Content, headings } = await render(post);

// 読了時間を推定（日本語は1分あたり約500文字、英語は200語）
const body = post.body || '';
const charCount = body.length;
const readingTime = Math.max(1, Math.ceil(charCount / 500));

// TOC用にheadingsをフォーマット
// rehype-autolink-headings が見出し末尾に '#' を append するため、TOC 表示用には除去する
const toc = headings
  .filter((h) => h.depth >= 2 && h.depth <= 3)
  .map((h) => ({
    id: h.slug,
    text: h.text.replace(/#\s*$/, ''),
    level: h.depth,
  }));

// 関連記事用に全記事メタデータを取得
const allPosts = await getPublishedPosts();
const allPostsMeta = allPosts.map((p) => ({
  slug: (p.data.slug || p.id),
  title: p.data.title,
  tags: p.data.tags || [],
  date: p.data.date,
}));
---

<BaseLayout
  title={`${post.data.title} | RK / Portfolio`}
  ogImage={`/og/${slug}.png`}
>
  <div class="article-layout">
    <!-- メインコンテンツ -->
    <article class="article" transition:name={`post-card-${encodeURIComponent(slug).replace(/%/g, '')}`}>
      <header class="article-header">
        <a href="/posts" class="back-link">← Posts</a>
        <h1 class="article-title" transition:name={`post-title-${encodeURIComponent(slug).replace(/%/g, '')}`}>{post.data.title}</h1>
        <div class="article-meta">
          <span class="article-meta__date" transition:name={`post-date-${encodeURIComponent(slug).replace(/%/g, '')}`}>{post.data.date}</span>
        </div>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="article-tags">
            {post.data.tags.map((tag: string) => (
              <a href={`/tags/${tag.replace(/\//g, '-')}`} class="badge">{tag}</a>
            ))}
          </div>
        )}
      </header>

      <ArticlePerformance
        client:load
        slug={slug}
        wordCount={charCount}
        readingTime={readingTime}
        publishDate={post.data.date}
      />

      <!-- モバイル用TOC -->
      {toc.length > 0 && (
        <nav class="mobile-toc">
          <h2 class="mobile-toc-title">目次</h2>
          <ul class="mobile-toc-list">
            {toc.map((item) => (
              <li style={`padding-left: ${(item.level - 2) * 1}rem`}>
                <a href={`#${item.id}`}>{item.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      <div class="prose">
        <Content components={{ img: CustomImage }} />
      </div>

      <!-- 記事フッター -->
      <footer class="article-footer">
        <ShareButtons
          client:load
          title={post.data.title}
          url={`https://dashboard-portfolio.vercel.app/posts/${slug}`}
        />
        <RelatedPosts
          client:load
          currentSlug={slug}
          currentTags={post.data.tags || []}
          allPosts={allPostsMeta}
        />
      </footer>

      <!-- クライアントサイド機能 -->
      <ImageZoom client:only="react" />
    </article>

    <!-- サイドバーTOC（デスクトップ） -->
    {toc.length > 0 && (
      <aside class="sidebar">
        <StickyToc client:load toc={toc} />
      </aside>
    )}
  </div>
</BaseLayout>

<script>
  function setupImageFigures() {
    const images = document.querySelectorAll('.prose img:not(.blog-figure-img)');
    
    images.forEach((img, index) => {
      // Avoid processing the same image twice
      if (img.parentElement?.tagName.toLowerCase() === 'figure') return;

      const altText = img.getAttribute('alt');
      const titleText = img.getAttribute('title');
      
      // title属性があればキャプションとして使い、なければalt属性をフォールバックとして使う
      const captionText = titleText || altText;
      const showCaption = captionText && captionText.trim().length > 0;

      const figure = document.createElement('figure');
      figure.className = 'blog-figure';

      // Insert figure before img, then move img into figure
      img.parentNode?.insertBefore(figure, img);
      
      // Add a specific class to prevent reprocessing or conflict with other img styles
      img.classList.add('blog-figure-img');
      figure.appendChild(img);

      if (showCaption) {
        const figcaption = document.createElement('figcaption');
        figcaption.innerHTML = `<span class="figure-number">図${index + 1}: </span>${captionText}`;
        figure.appendChild(figcaption);
      }
    });
  }

  // Run on initial load and setup a listener for Astro View Transitions if used
  document.addEventListener('DOMContentLoaded', () => {
    setupImageFigures();
    setupSidenotes();
    setupHeadingAnchorCopy();
  });
  document.addEventListener('astro:page-load', () => {
    setupImageFigures();
    setupSidenotes();
    setupHeadingAnchorCopy();
  });

  /**
   * 見出し横の '#' クリックでセクション URL をクリップボードにコピー、
   * 直後に 'Copied!' ツールチップに切り替える。
   * 委譲リスナを document に 1 回だけ登録する。
   */
  function setupHeadingAnchorCopy() {
    if ((window as any).__headingAnchorCopyBound) return;
    (window as any).__headingAnchorCopyBound = true;

    document.addEventListener('click', async (event) => {
      const target = event.target as HTMLElement | null;
      const anchor = target?.closest('.heading-anchor') as HTMLAnchorElement | null;
      if (!anchor) return;

      const href = anchor.getAttribute('href');
      if (!href) return;

      const url = `${window.location.origin}${window.location.pathname}${href}`;
      try {
        await navigator.clipboard.writeText(url);
        anchor.classList.add('is-copied');
        window.setTimeout(() => anchor.classList.remove('is-copied'), 1500);
      } catch (err) {
        console.warn('Failed to copy section URL', err);
      }
    });
  }

  /**
   * 脚注（.footnotes セクション）をサイドノートとして本文横に展開する
   * デスクトップ: float で右余白に配置
   * モバイル: インライン表示にフォールバック
   */
  function setupSidenotes() {
    const footnoteSection = document.querySelector('.footnotes');
    if (!footnoteSection) return;

    const refs = document.querySelectorAll('sup a[data-footnote-ref]');
    refs.forEach((ref) => {
      const href = ref.getAttribute('href');
      if (!href) return;
      // href は "#user-content-fn-1" など
      const id = href.replace(/^#/, '');
      const footnoteItem = footnoteSection.querySelector(`#${CSS.escape(id)}`);
      if (!footnoteItem) return;

      // サイドノート要素を生成
      const sidenote = document.createElement('span');
      sidenote.className = 'sidenote';
      sidenote.setAttribute('role', 'note');
      
      // 読み上げ時に注釈番号がわかるように aria-label を付与
      const noteNumber = ref.textContent?.trim() || '';
      sidenote.setAttribute('aria-label', noteNumber ? `注釈 ${noteNumber}` : '注釈');

      // li の中身を取得（バックリンクを除く）
      const clone = footnoteItem.cloneNode(true);
      clone.querySelectorAll('a[data-footnote-backref]').forEach((el) => el.remove());
      sidenote.innerHTML = clone.innerHTML;

      // 脚注参照 <sup> の直後に挿入
      const sup = ref.closest('sup');
      if (sup?.parentNode) {
        sup.parentNode.insertBefore(sidenote, sup.nextSibling);
      }

      // 脚注リンクのクリックによる不要なジャンプを無効化
      ref.addEventListener('click', (e) => e.preventDefault());
      ref.style.cursor = 'default'; // ジャンプしないためカーソルを変更
    });
  }
</script>

<style>
  .article-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
    max-width: 1100px;
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .article-layout {
      grid-template-columns: 1fr 280px;
    }
  }

  .article {
    min-width: 0;
  }

  .sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .sidebar {
      display: block;
    }
  }

  .article-header {
    margin-bottom: var(--spacing-xl);
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-primary);
    margin-bottom: var(--spacing-lg);
  }

  .article-title {
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: var(--spacing-md);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-md);
  }

  .meta-separator {
    color: var(--color-text-muted);
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
  }

  /* モバイルTOC */
  .mobile-toc {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-left: 2px solid var(--color-primary);
    padding: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }

  @media (min-width: 1024px) {
    .mobile-toc {
      display: none;
    }
  }

  .mobile-toc-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-sm);
  }

  .mobile-toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mobile-toc-list li {
    margin-bottom: var(--spacing-xs);
  }

  .mobile-toc-list a {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .mobile-toc-list a:hover {
    color: var(--color-primary);
  }

  /* Prose styles for Markdown content */
  .prose {
    line-height: 1.8;
  }

  .prose :global(h2) {
    font-size: var(--p-step-2);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-block-start: var(--s-space-gap-md);
    margin-block-end: var(--s-space-gutter-xs);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    scroll-margin-top: calc(var(--header-height) + var(--spacing-lg));
  }

  .prose :global(h3) {
    font-size: var(--p-step-1);
    font-weight: 600;
    margin-block-start: var(--s-space-gap-sm);
    margin-block-end: var(--s-space-gutter-xs);
    scroll-margin-top: calc(var(--header-height) + var(--spacing-lg));
  }

  .prose :global(.heading-anchor) {
    position: relative;
    margin-left: 0.4em;
    color: var(--color-text-muted);
    font-weight: 400;
    text-decoration: none;
    opacity: 0;
    transition: opacity 150ms ease, color 80ms ease;
  }

  .prose :global(h2:hover .heading-anchor),
  .prose :global(h3:hover .heading-anchor),
  .prose :global(.heading-anchor:focus),
  .prose :global(.heading-anchor.is-copied) {
    opacity: 1;
  }

  .prose :global(.heading-anchor:hover),
  .prose :global(.heading-anchor:focus) {
    color: var(--color-primary);
  }

  /* 自前ツールチップ (native title はラグがあるため使わない) */
  .prose :global(.heading-anchor::after) {
    content: 'このセクションへのリンク';
    position: absolute;
    bottom: calc(100% + 4px);
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    background-color: var(--color-bg-card);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    padding: 4px 8px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    line-height: 1;
    opacity: 0;
    pointer-events: none;
    transition: opacity 80ms ease;
  }

  .prose :global(.heading-anchor:hover::after),
  .prose :global(.heading-anchor:focus::after),
  .prose :global(.heading-anchor.is-copied::after) {
    opacity: 1;
  }

  .prose :global(.heading-anchor.is-copied::after) {
    content: 'Copied!';
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .prose :global(p) {
    margin-block: 0.75lh;
  }

  .prose :global(:is(p, li):not([class])),
  .prose :global(dd),
  .prose :global(small) {
    max-inline-size: 40em;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .prose :global(:not(pre) > code) {
    background-color: var(--color-bg-secondary);
    padding: 0.125rem 0.375rem;
    font-size: 0.875em;
    font-family: var(--font-mono);
    border: 1px solid var(--color-border);
  }

  .prose :global(.expressive-code) {
    margin-block: 1rem;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding-left: var(--spacing-md);
    margin: 1.5rem 0;
    color: var(--color-text-secondary);
    font-style: normal;
    letter-spacing: 0.02em;
  }

  /* Dynamically created figures via JS */
  .prose :global(.blog-figure) {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 2.5rem 0;
    width: 100%;
  }

  /* Max-height fix for tall vertical images */
  .prose :global(.blog-figure-img) {
    max-width: 100%;
    max-height: 60vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 8px;
    background-color: var(--color-surface, #f5f5f5);
  }

  .prose :global(.blog-figure figcaption) {
    margin-top: 1rem;
    font-size: 0.9rem;
    color: var(--color-text-muted, #666);
    text-align: center;
    line-height: 1.5;
  }

  .prose :global(.figure-number) {
    font-weight: 600;
  }

  .prose :global(img:not(.blog-figure-img)) {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--color-border);
    margin: 1.5rem 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1rem;
  }

  .prose :global(th),
  .prose :global(td) {
    border: 1px solid var(--color-border);
    padding: var(--spacing-sm) var(--spacing-md);
    text-align: left;
  }

  .prose :global(th) {
    background-color: var(--color-bg-secondary);
    font-weight: 600;
  }

  /* ===== 脚注 / サイドノート ===== */

  /* ページ下部のデフォルト脚注セクションを非表示にする */
  .prose :global(.footnotes) {
    display: none;
  }

  /* 脚注参照リンク（上付き数字） */
  .prose :global(sup a[data-footnote-ref]) {
    color: var(--color-primary);
    font-size: 0.7em;
    font-weight: 700;
    text-decoration: none;
    padding: 0 1px;
  }

  .prose :global(sup a[data-footnote-ref]:hover) {
    color: var(--color-accent-2);
  }

  /* サイドノート本体 — デスクトップ: 右余白に float */
  .prose :global(.sidenote) {
    display: block;
    float: right;
    clear: right;
    width: 180px;
    margin-right: -210px;
    margin-top: 0.2em;
    margin-bottom: 0.5em;
    padding: 6px 8px;
    font-size: 0.72rem;
    line-height: 1.5;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    border-left: 2px solid var(--color-primary);
    opacity: 0.85;
  }

  /* モバイル: float 解除してインライン表示 */
  @media (max-width: 1023px) {
    .prose :global(.sidenote) {
      float: none;
      clear: none;
      width: 100%;
      margin-right: 0;
      margin: 0.75rem 0;
      padding: 0.5rem 0.75rem;
      background-color: var(--color-bg-secondary);
      border-left: 2px solid var(--color-primary);
    }
  }
</style>
