---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getPublishedPosts } from '../../utils/posts';
import PostSearch from '../../components/PostSearch';
import ArticleNetworkGraph from '../../components/ArticleNetworkGraph';

const posts = await getPublishedPosts();
const sortedPosts = posts
  .map((post) => ({
    slug: (post.data.slug || post.id),
    title: post.data.title,
    date: post.data.date,
    excerpt: post.data.excerpt || '',
    tags: post.data.tags || [],
    thumbnail: post.data.thumbnail || '',
  }))
  .sort((a, b) => (a.date < b.date ? 1 : -1));

// 全タグリスト（出現回数順）
const tagCount = new Map<string, number>();
sortedPosts.forEach((post) => {
  post.tags.forEach((tag) => {
    tagCount.set(tag, (tagCount.get(tag) || 0) + 1);
  });
});
const allTags = Array.from(tagCount.entries())
  .sort((a, b) => b[1] - a[1])
  .map(([tag]) => tag);
---

<BaseLayout title="RK / Posts">
  <div class="page-header">
    <h1 class="page-title">Posts</h1>
    <div class="stats-row">
      <span class="stat-item">{sortedPosts.length} Posts</span>
      <span class="stat-separator">/</span>
      <span class="stat-item">{allTags.length} Tags</span>
      <span class="stat-separator">/</span>
      <span class="stat-item">Latest: {sortedPosts[0]?.date}</span>
    </div>
  </div>

  <details class="graph-details">
    <summary class="graph-summary">
      <span class="summary-icon">◈</span>
      <span class="summary-text">Explore Article Network Graph</span>
    </summary>
    <div class="graph-wrapper">
      <ArticleNetworkGraph client:only="react" posts={sortedPosts} />
    </div>
  </details>

  <PostSearch client:load posts={sortedPosts} allTags={allTags} />
</BaseLayout>

<style>
  .page-header {
    margin-bottom: var(--spacing-xl);
  }

  .page-title {
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    margin-bottom: var(--spacing-sm);
  }

  .stats-row {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .stat-item {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .stat-separator {
    color: var(--color-border);
  }

  /* Accordion for Network Graph */
  .graph-details {
    margin-bottom: var(--spacing-lg);
    border: 1px solid var(--color-border);
    background-color: var(--color-bg-card);
  }

  .graph-summary {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-md);
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: var(--font-mono);
    color: var(--color-text-secondary);
    user-select: none;
    list-style: none; /* デフォルトの矢印を非表示 */
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .graph-summary::-webkit-details-marker {
    display: none; /* Safari向け矢印非表示 */
  }

  .graph-summary:hover {
    color: var(--color-primary);
    background-color: var(--color-bg-secondary);
  }

  .summary-icon {
    font-size: 0.85rem;
    color: var(--color-primary);
    transition: transform var(--transition-fast);
  }

  .graph-details[open] .summary-icon {
    transform: rotate(45deg);
  }

  .graph-wrapper {
    border-top: 1px solid var(--color-border);
    padding: var(--spacing-sm);
    background-color: var(--color-bg-card);
  }
</style>
