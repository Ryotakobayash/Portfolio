---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../utils/posts';
import LifeProgress from '../components/LifeProgress';
import CreativeLifeCountdown from '../components/CreativeLifeCountdown';
import PostBurndown from '../components/PostBurndown';
import GitHubActivity from '../components/GitHubActivity';
import goalsData from '../data/goals.json';

// 全記事の日付を取得（バーンダウン用）
const posts = await getPublishedPosts();
const postDates = posts.map((post) => ({
    slug: (post.data.slug || post.id.replace(/\.mdx?$/, '')),
    date: post.data.date,
}));
---

<BaseLayout title="RK / About" description="小林 諒大のプロフィールとダッシュボード">
  <div class="about">
    <!-- Hero Section -->
    <section class="hero">
      <div class="avatar avatar--large">KR</div>
      <div class="hero-text">
        <h1 class="hero-name">Ryota Kobayashi</h1>
        <p class="hero-subtitle">小林 諒大</p>
        <p class="hero-role">Product Designer @ Cybozu, Inc.</p>
      </div>
    </section>

    <hr class="divider" />

    <!-- ===== Time Remaining ===== -->
    <section class="section">
      <h2 class="section-title"><span>01 · Time Remaining</span></h2>
      <div class="me-grid me-grid--2col">
          <div class="bento-card">
              <LifeProgress
                  client:load
                  birthYear={goalsData.lifeExpectancy.birthYear}
                  expectedAge={goalsData.lifeExpectancy.expectedAge}
              />
          </div>
          <div class="bento-card">
              <CreativeLifeCountdown
                  client:load
                  startDate={goalsData.creativeLife.start}
                  endDate={goalsData.creativeLife.end}
              />
          </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- ===== Post Count ===== -->
    <section class="section">
      <h2 class="section-title"><span>02 · Post Count {goalsData.posts.period}</span></h2>
      <div class="bento-card">
          <PostBurndown
              client:only="react"
              posts={postDates}
              yearlyTarget={goalsData.posts.yearlyTarget}
              period={goalsData.posts.period}
          />
      </div>
    </section>

    <hr class="divider" />

    <!-- ===== GitHub Activity ===== -->
    <section class="section">
      <h2 class="section-title"><span>03 · GitHub Activity</span></h2>
      <div class="bento-card">
          <GitHubActivity client:load />
      </div>
    </section>

    <hr class="divider" />

    <!-- Links Section -->
    <section class="section">
      <h2 class="section-title"><span>04 · Links</span></h2>
      <div class="links">
        <a href="https://github.com/Ryotakobayash" target="_blank" rel="noopener" class="link-item">
          GitHub
        </a>
        <a href="https://speakerdeck.com/ryota5884" target="_blank" rel="noopener" class="link-item">
          Speaker Deck
        </a>
        <a href="https://zenn.dev/ryota5884" target="_blank" rel="noopener" class="link-item">
          Zenn
        </a>
        <a href="https://note.com/tender_hyssop572" target="_blank" rel="noopener" class="link-item">
          note
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .about {
    max-width: 800px;
    margin: 0 auto;
  }

  .divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--spacing-xl) 0;
  }

  /* Hero */
  .hero {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-xl);
  }

  .avatar--large {
    width: 100px;
    height: 100px;
    font-size: 2rem;
    flex-shrink: 0;
  }

  .hero-name {
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    margin-bottom: var(--spacing-xs);
  }

  .hero-subtitle {
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-sm);
  }

  .hero-role {
    font-size: 1rem;
  }

  /* Section */
  .section-title {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-lg);
  }

  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .me-grid {
    display: grid;
    gap: var(--spacing-lg);
  }

  .me-grid--2col {
    grid-template-columns: 1fr 1fr;
  }

  /* Links */
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md);
  }

  .link-item {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-xs) var(--spacing-md);
    background-color: transparent;
    border: 1px solid var(--color-border);
    text-decoration: none;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .link-item:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  @media (max-width: 700px) {
    .me-grid--2col {
      grid-template-columns: 1fr;
    }
  }
</style>
