---
/**
 * 関連記事レコメンド コンポーネント
 * 共通タグ数でスコアリングし、上位3件を表示
 */
interface PostMeta {
    slug: string;
    title: string;
    tags: string[];
    date: string;
}

interface Props {
    currentSlug: string;
    currentTags: string[];
    allPosts: PostMeta[];
}

const { currentSlug, currentTags, allPosts } = Astro.props;

// 共通タグ数でスコアリング
const scored = allPosts
    .filter((p) => p.slug !== currentSlug)
    .map((post) => {
        const commonTags = post.tags.filter((t) => currentTags.includes(t));
        return { ...post, score: commonTags.length, commonTags };
    })
    .filter((p) => p.score > 0)
    .sort((a, b) => b.score - a.score || (a.date < b.date ? 1 : -1))
    .slice(0, 3);
---

{scored.length > 0 && (
    <div class="related-posts">
        <h3 class="related-posts__title">Related Articles</h3>
        <div class="related-posts__grid">
            {scored.map((post) => (
                <a href={`/posts/${post.slug}`} class="related-posts__card">
                    <span class="related-posts__card-title">{post.title}</span>
                    <span class="related-posts__card-date">{post.date}</span>
                    <div class="related-posts__tags">
                        {post.commonTags.map((tag) => (
                            <span class="related-posts__tag">{tag}</span>
                        ))}
                    </div>
                </a>
            ))}
        </div>
    </div>
)}

<style>
    .related-posts {
        margin-top: 24px;
    }

    .related-posts__title {
        font-size: 0.6rem;
        font-weight: 600;
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.25em;
        margin-bottom: 12px;
    }

    .related-posts__grid {
        display: grid;
        gap: 12px;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    }

    .related-posts__card {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 12px;
        border: 1px solid var(--color-border);
        background-color: var(--color-bg-card);
        text-decoration: none;
        color: inherit;
        transition: border-color 120ms ease;
    }

    .related-posts__card:hover {
        border-color: var(--color-primary);
    }

    .related-posts__card-title {
        font-size: 0.85rem;
        font-weight: 500;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .related-posts__card-date {
        font-size: 0.75rem;
        color: var(--color-text-muted);
    }

    .related-posts__tags {
        display: flex;
        gap: 4px;
        flex-wrap: wrap;
    }

    .related-posts__tag {
        font-size: 0.6rem;
        padding: 1px 5px;
        border: 1px solid var(--color-primary);
        color: var(--color-primary);
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }
</style>
