---
import SlideAsciiCanvas from './SlideAsciiCanvas';

interface Props {
  opacity?: number;
  characters?: string;
  modelUrl?: string;
  scale?: number;
  speed?: number;
}
const {
  opacity = 0.6,
  characters,
  modelUrl,
  scale,
  speed,
} = Astro.props;
---
<div class="slide-ascii" style={`--ascii-opacity: ${opacity}`}>
  <SlideAsciiCanvas
    client:only="react"
    characters={characters}
    modelUrl={modelUrl}
    scale={scale}
    speed={speed}
  />
</div>

<style>
  /* Positioned against the Slide section (via name="backdrop" slot).
     Negative inset extends past Slide's padding to cover edge-to-edge. */
  .slide-ascii {
    position: absolute;
    top: -4cqi;
    right: -5cqi;
    bottom: -4cqi;
    left: -5cqi;
    pointer-events: none;
    opacity: var(--ascii-opacity);
    color: var(--color-text-secondary);
    overflow: hidden;
  }
</style>
