---
interface Props {
  src: string;
  alt?: string;
  caption?: string;
  fit?: 'contain' | 'cover';
  bare?: boolean;
}
const { src, alt = '', caption, fit = 'contain', bare = false } = Astro.props;
---
<figure class="image-slide" data-fit={fit} data-bare={bare}>
  <img src={src} alt={alt} />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .image-slide {
    margin: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5cqi;
    min-height: 0;
  }

  .image-slide img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    border: 1px solid var(--color-border);
    margin: 0;
  }

  .image-slide[data-fit="cover"] img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-slide[data-bare="true"] img {
    border: none;
  }

  .image-slide figcaption {
    font-family: var(--font-mono);
    font-size: 1.1cqi;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    text-align: center;
  }
</style>
