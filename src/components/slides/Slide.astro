---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---
<section class:list={['slide', className]} data-slide>
  <slot name="backdrop" />
  <div class="slide-body">
    <slot />
  </div>
  <slot name="footnote" />
</section>

<style>
  .slide {
    /* Container query unit basis: child sizes (cqi) scale with slide width,
       so layout looks identical whether windowed or fullscreen. */
    container-type: inline-size;
    display: none;
    position: absolute;
    inset: 0;
    flex-direction: column;
    padding: 4cqi 5cqi;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .slide.is-active {
    display: flex;
  }

  /* SSR fallback: show first slide when JS hasn't yet marked one active.
     Prevents an all-black flash on initial load / View Transitions race. */
  :global(.slides-container:not(:has(.slide.is-active))) .slide:first-of-type {
    display: flex;
  }

  .slide-body {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    gap: 1.2cqi;
    font-weight: 400;
  }

  .slide :global(h1) {
    font-size: 5.5cqi;
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1.1;
    margin: 0 0 0.3em;
  }

  .slide :global(h2) {
    font-size: 3.2cqi;
    font-weight: 700;
    color: var(--color-primary);
    margin: 0 0 0.5em;
  }

  .slide :global(h3) {
    font-size: 2.4cqi;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.4em;
  }

  .slide :global(p) {
    font-size: 2cqi;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0 0 0.5em;
  }

  .slide :global(ul),
  .slide :global(ol) {
    font-size: 2cqi;
    line-height: 1.8;
    color: var(--color-text-secondary);
    padding-left: 1.4em;
    margin: 0;
  }

  .slide :global(ul) {
    list-style: none;
    padding-left: 0;
  }

  .slide :global(ul > li) {
    position: relative;
    padding-left: 1.4em;
  }

  .slide :global(ul > li)::before {
    content: "▸";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  .slide :global(ul ul) {
    margin-top: 0.3em;
    font-size: 0.95em;
  }

  .slide :global(ul ul > li)::before {
    content: "–";
    color: var(--color-text-muted);
  }

  .slide :global(ol) {
    list-style: none;
    padding-left: 0;
    counter-reset: slide-ol;
  }

  .slide :global(ol > li) {
    position: relative;
    padding-left: 1.8em;
    counter-increment: slide-ol;
  }

  .slide :global(ol > li)::before {
    content: counter(slide-ol) ".";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-weight: 700;
  }

  .slide :global(ol ol) {
    margin-top: 0.3em;
    font-size: 0.95em;
    counter-reset: slide-ol-nested;
  }

  .slide :global(ol ol > li) {
    counter-increment: slide-ol-nested;
  }

  .slide :global(ol ol > li)::before {
    content: counter(slide-ol-nested, lower-alpha) ".";
    color: var(--color-text-muted);
  }

  .slide :global(li + li) {
    margin-top: 0.3em;
  }

  .slide :global(strong) {
    color: var(--color-text);
    font-weight: 700;
  }

  .slide :global(em) {
    color: var(--color-accent-2);
    font-style: normal;
  }

  .slide :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  .slide :global(mark) {
    background: var(--color-primary-light);
    color: inherit;
    padding: 0 0.2em;
  }

  .slide :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 1.5cqi 0;
  }

  .slide :global(blockquote) {
    margin: 0.8cqi 0;
    padding: 0.4cqi 0 0.4cqi 1.5cqi;
    border-left: 2px solid var(--color-border);
    color: var(--color-text-secondary);
    font-size: 2cqi;
    line-height: 1.6;
  }

  .slide :global(kbd) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    padding: 0.1em 0.5em;
    color: var(--color-text);
  }

  .slide :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg-secondary);
    padding: 0.1em 0.4em;
    border: 1px solid var(--color-border);
    color: var(--color-accent-2);
  }

  .slide :global(pre) {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    padding: 1rem 1.25rem;
    overflow-x: auto;
    font-size: 1.6cqi;
    line-height: 1.6;
  }

  .slide :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--color-text);
  }

  .slide :global(img) {
    display: block;
    max-width: 100%;
    max-height: 70cqb;
    width: auto;
    height: auto;
    margin: 0.5em auto;
    object-fit: contain;
    border: 1px solid var(--color-border);
  }

  .slide :global(figure) {
    margin: 0.5em auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4em;
  }

  .slide :global(figure img) {
    margin: 0;
  }

  .slide :global(figcaption) {
    font-size: 1.4cqi;
    color: var(--color-text-secondary);
    text-align: center;
  }
</style>
