---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---
<section class:list={['slide', className]} data-slide>
  <div class="slide-body">
    <slot />
  </div>
</section>

<style>
  .slide {
    /* Container query unit basis: child sizes (cqi) scale with slide width,
       so layout looks identical whether windowed or fullscreen. */
    container-type: inline-size;
    display: none;
    position: absolute;
    inset: 0;
    flex-direction: column;
    padding: 4cqi 5cqi;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .slide.is-active {
    display: flex;
  }

  /* SSR fallback: show first slide when JS hasn't yet marked one active.
     Prevents an all-black flash on initial load / View Transitions race. */
  :global(.slides-container:not(:has(.slide.is-active))) .slide:first-of-type {
    display: flex;
  }

  .slide-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    gap: 1.2cqi;
  }

  .slide :global(h1) {
    font-size: 4cqi;
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1.1;
    margin: 0 0 0.3em;
  }

  .slide :global(h2) {
    font-size: 2.4cqi;
    font-weight: 700;
    color: var(--color-primary);
    margin: 0 0 0.5em;
  }

  .slide :global(h3) {
    font-size: 1.8cqi;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.4em;
  }

  .slide :global(p) {
    font-size: 1.5cqi;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0 0 0.5em;
  }

  .slide :global(ul),
  .slide :global(ol) {
    font-size: 1.5cqi;
    line-height: 1.8;
    color: var(--color-text-secondary);
    padding-left: 1.4em;
    margin: 0;
  }

  .slide :global(li + li) {
    margin-top: 0.3em;
  }

  .slide :global(strong) {
    color: var(--color-text);
    font-weight: 700;
  }

  .slide :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg-secondary);
    padding: 0.1em 0.4em;
    border: 1px solid var(--color-border);
    color: var(--color-accent-2);
  }

  .slide :global(pre) {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    padding: 1rem 1.25rem;
    overflow-x: auto;
    font-size: 1.2cqi;
    line-height: 1.6;
  }

  .slide :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--color-text);
  }
</style>
