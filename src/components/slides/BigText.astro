---
interface Props {
  size?: 'md' | 'lg' | 'xl' | '2xl' | 'fill';
  align?: 'start' | 'center' | 'end';
  accent?: boolean;
}
const { size = 'xl', align = 'center', accent = false } = Astro.props;
---
<div class="big-text" data-size={size} data-align={align} data-accent={accent}>
  <slot />
</div>

<style>
  .big-text {
    flex: 1;
    display: flex;
    align-items: center;
    text-align: center;
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--color-text);
  }

  .big-text[data-align="start"] {
    justify-content: flex-start;
    text-align: left;
  }
  .big-text[data-align="center"] {
    justify-content: center;
    text-align: center;
  }
  .big-text[data-align="end"] {
    justify-content: flex-end;
    text-align: right;
  }

  .big-text[data-size="md"] { font-size: 4cqi; }
  .big-text[data-size="lg"] { font-size: 5.5cqi; }
  .big-text[data-size="xl"] { font-size: 7cqi; }
  .big-text[data-size="2xl"] { font-size: 9cqi; }
  /* fill — 一番長い行（およそ 16 文字想定）がスライド幅の 8 割ほどに収まり、
     折り返さずに横いっぱいへ伸びるサイズ感。 */
  .big-text[data-size="fill"] {
    font-size: 5cqi;
    line-height: 1.15;
  }

  .big-text[data-accent="true"] { color: var(--color-text); }

  /* MDX が中身を <p> で包むため、Slide.astro 側の `.slide :global(p)`
     （font-size: 2cqi, color: var(--color-text-secondary), margin あり）
     を打ち消して BigText 自身の font-size / 色 / 行送りを継承させる。 */
  .big-text :global(p) {
    font-size: inherit;
    color: inherit;
    line-height: inherit;
    margin: 0;
  }

  .big-text :global(strong) {
    color: var(--color-primary);
    font-weight: inherit;
  }

  .big-text :global(em) {
    color: var(--color-accent-2);
    font-style: normal;
  }
</style>
